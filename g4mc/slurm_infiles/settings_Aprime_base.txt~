/run/verbose 2
/control/verbose 0
/tracking/verbose 0
/stepping/verbose 0
/mydet/verbose 0
/tracking/particleOnly e-

/stepping/makeTXToutput false
/stepping/killAtQ1 true

# for the full simulation noSecondary 0, it only the primary track is needed to be simulated - then /tracking/noSecondary 1
/tracking/noSecondary 1
/tracking/thisTrackOnly 0
#see the same variable in HRSUsage.ini


# vertex bounds for uniform generation. These reflect the approximate 'box'
# from which the raster/ APEX tungsten foil targets may generate vertices. 

/mydet/gunXLow  -2.0 mm
/mydet/gunXHigh  2.0 mm

/mydet/gunYLow  -2.0 mm
/mydet/gunYHigh  2.0 mm

/mydet/gunZLow  -240.0 mm
/mydet/gunZHigh  330.0 mm

# track positions (projected onto the sieve plane)

/mydet/simulateSieve false


# RHRS settings
/mydet/R_sieveXLow    -55.0 mm
/mydet/R_sieveXHigh    55.0 mm
/mydet/R_sieveYLow    -45.0 mm 
/mydet/R_sieveYHigh    65.0 mm

# LHRS settings
/mydet/L_sieveXLow    -55.0 mm
/mydet/L_sieveXHigh    55.0 mm
/mydet/L_sieveYLow    -65.0 mm 
/mydet/L_sieveYHigh    45.0 mm

# Mass of A' to simulate

/mydet/generate_A-prime true
/mydet/A-prime_mass 170 MeV

/mydet/electron_energy_min 1030 MeV
/mydet/electron_energy_max 1170 MeV
/mydet/beam_energy 2200 MeV

/mydet/target_type production-foils

/mydet/particle1/momentumLow  1058 MeV
/mydet/particle1/momentumHigh 1149 MeV

/mydet/particleNum 1
/mydet/particle1/particleName e-

/mydet/use_RHRS false

/mydet/outfile Aprime_test_L.root
